# ── Aplicación ──────────────────────────────────────────────────────────────
APP_NAME="Food Store API"
APP_VERSION="0.1.0"
ENV=dev                         # dev | test | prod
DEBUG=true                      # En prod debe ser false

# ── Base de datos ────────────────────────────────────────────────────────────
# Obligatorio a partir del change infra-database. Opcional en este change.
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/foodstore

# ── Seguridad ────────────────────────────────────────────────────────────────
# Obligatorio. Mínimo 32 caracteres. Generá uno con:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=changeme-min-32-chars-please-rotate-this-value

# ── JWT ──────────────────────────────────────────────────────────────────────
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ── CORS ─────────────────────────────────────────────────────────────────────
# Acepta CSV o JSON array. No usar wildcard (*).
# En prod restringir al dominio real: CORS_ORIGINS=https://tudominio.com
CORS_ORIGINS=http://localhost:5173

# ── MercadoPago ──────────────────────────────────────────────────────────────
# Opcional en dev. Obligatorio para el change mercadopago-integration.
# MERCADOPAGO_ACCESS_TOKEN=TEST-xxxxxxxxxxxxxxxxxxxx
# MERCADOPAGO_PUBLIC_KEY=TEST-xxxxxxxxxxxxxxxxxxxx

# ── Rate limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_DEFAULT=60/minute
# Opcional. None = memoria en proceso (dev/test). Redis para replicas en prod.
# RATE_LIMIT_STORAGE_URI=redis://localhost:6379/0

# ── Payload ──────────────────────────────────────────────────────────────────
MAX_BODY_SIZE_BYTES=1048576     # 1 MB
